{
    "expo": {
        "name": "Wallet",
        "slug": "wallet",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/logo.png",
        "scheme": "wallet",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.vedtellawar.wallet",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "package": "com.vedtellawar.wallet",
            "versionCode": 1,
            "permissions": ["NOTIFICATIONS", "INTERNET"],
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/logo.png",
                "backgroundColor": "#E5D3B7"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "intentFilters": [
                {
                    "action": "VIEW",
                    "data": [
                        {
                            "scheme": "wallet"
                        }
                    ],
                    "category": ["BROWSABLE", "DEFAULT"]
                }
            ]
        },
        "androidStatusBar": {
            "backgroundColor": "#FFF8F3",
            "barStyle": "dark-content"
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/logo.png",
            "bundler": "metro"
        },
        "plugins": [
            "expo-router",
            "expo-notifications",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/logo.png",
                    "imageWidth": 140,
                    "resizeMode": "contain",
                    "backgroundColor": "#FFF8F3",
                    "dark": {
                        "backgroundColor": "#FFF8F3"
                    }
                }
            ],
            "expo-font"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "c2f9ce3a-f945-4107-9419-97f15daaed86"
            }
        }
    }
}
